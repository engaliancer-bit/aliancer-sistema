import React, { useState, useEffect } from 'react';
import {
  Home, FileText, Bell, Settings, LogOut, Building,
  CheckCircle, Clock, AlertCircle, MessageSquare, Plus,
  Download, Eye, CheckSquare, XCircle, ArrowRight, Paperclip,
  Image as ImageIcon, File
} from 'lucide-react';
import { supabase } from '../lib/supabase';

interface Customer {
  id: string;
  name: string;
  phone: string;
  email: string;
}

interface Property {
  id: string;
  name: string;
  registration_number: string;
  area: number;
  municipality: string;
  state: string;
  document_count: number;
}

interface Project {
  id: string;
  title: string;
  service_type: string;
  status: string;
  progress_percentage: number;
  current_phase: string;
  estimated_completion_date: string;
  property_name: string;
}

interface Notification {
  id: string;
  type: string;
  title: string;
  message: string;
  priority: string;
  is_read: boolean;
  created_at: string;
  action_url?: string;
  action_label?: string;
}

interface ServiceRequest {
  id: string;
  service_type: string;
  title: string;
  description: string;
  urgency: string;
  status: string;
  created_at: string;
  response_notes?: string;
}

interface ServiceApproval {
  id: string;
  title: string;
  description: string;
  estimated_value: number;
  estimated_days: number;
  status: string;
  expires_at: string;
  created_at: string;
}

export default function ClientPortal() {
  const [token, setToken] = useState('');
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [customer, setCustomer] = useState<Customer | null>(null);
  const [activeTab, setActiveTab] = useState<'home' | 'properties' | 'projects' | 'services' | 'notifications'>('home');

  // Data states
  const [properties, setProperties] = useState<Property[]>([]);
  const [projects, setProjects] = useState<Project[]>([]);
  const [notifications, setNotifications] = useState<Notification[]>([]);
  const [serviceRequests, setServiceRequests] = useState<ServiceRequest[]>([]);
  const [serviceApprovals, setServiceApprovals] = useState<ServiceApproval[]>([]);

  // Form states
  const [showNewRequest, setShowNewRequest] = useState(false);
  const [newRequest, setNewRequest] = useState({
    service_type: 'topografia',
    title: '',
    description: '',
    urgency: 'normal',
    property_id: ''
  });

  const [loading, setLoading] = useState(false);
  const [selectedProperty, setSelectedProperty] = useState<string | null>(null);
  const [propertyDocuments, setPropertyDocuments] = useState<any[]>([]);
  const [propertyAttachments, setPropertyAttachments] = useState<any[]>([]);

  useEffect(() => {
    console.log('🟢 ClientPortal: Iniciando validação de token');
    console.log('📍 URL completa:', window.location.href);

    // Tentar capturar token de várias formas
    let tokenToUse = null;

    // 1. Tentar via param portal (formato novo: ?portal=xxx)
    const urlParams = new URLSearchParams(window.location.search);
    const portalToken = urlParams.get('portal');
    console.log('🔍 Portal token:', portalToken ? 'Sim' : 'Não');

    if (portalToken) {
      console.log('✅ Token encontrado via portal param:', portalToken.substring(0, 10) + '...');
      tokenToUse = portalToken;
    }

    // 2. Tentar via hash (formato: #client-portal?token=xxx)
    if (!tokenToUse) {
      const hash = window.location.hash;
      console.log('🔍 Hash:', hash);

      if (hash && hash.includes('?')) {
        const hashParams = new URLSearchParams(hash.split('?')[1]);
        const hashToken = hashParams.get('token');
        if (hashToken) {
          console.log('✅ Token encontrado via hash:', hashToken.substring(0, 10) + '...');
          tokenToUse = hashToken;
        }
      }
    }

    // 3. Tentar via query params (formato antigo: ?token=xxx)
    if (!tokenToUse) {
      const urlToken = urlParams.get('token');
      console.log('🔍 Query params token:', window.location.search);

      if (urlToken) {
        console.log('✅ Token encontrado via query params:', urlToken.substring(0, 10) + '...');
        tokenToUse = urlToken;
      }
    }

    // 4. Tentar token salvo no localStorage
    if (!tokenToUse) {
      const savedToken = localStorage.getItem('client_portal_token');
      console.log('🔍 Token salvo no localStorage:', savedToken ? 'Sim' : 'Não');

      if (savedToken) {
        console.log('✅ Usando token salvo do localStorage');
        tokenToUse = savedToken;
      }
    }

    // Validar o token encontrado
    if (tokenToUse) {
      validateToken(tokenToUse);
    } else {
      console.log('❌ Nenhum token encontrado em nenhum lugar');
    }
  }, []);

  useEffect(() => {
    if (isAuthenticated && customer) {
      loadAllData();
    }
  }, [isAuthenticated, customer]);

  const validateToken = async (tokenToValidate: string) => {
    try {
      setLoading(true);
      console.log('🔍 Validando token:', tokenToValidate.substring(0, 20) + '...');

      const { data, error } = await supabase.rpc('validate_customer_token', {
        p_token: tokenToValidate
      });

      console.log('📦 Resposta da validação:', { data, error });

      if (error) {
        console.error('❌ Erro na validação:', error);
        throw error;
      }

      if (data && data.length > 0) {
        const customerData = data[0];
        console.log('✅ Token válido! Cliente:', customerData.customer_name);

        setCustomer({
          id: customerData.customer_id,
          name: customerData.customer_name,
          phone: customerData.customer_phone,
          email: customerData.customer_email
        });
        setToken(tokenToValidate);
        setIsAuthenticated(true);
        localStorage.setItem('client_portal_token', tokenToValidate);
      } else {
        console.warn('⚠️ Token não retornou dados');
        alert('Token inválido ou expirado. Por favor, solicite um novo acesso.');
      }
    } catch (error: any) {
      console.error('❌ Erro ao validar token:', error);
      alert(`Erro ao validar acesso: ${error.message || 'Erro desconhecido'}`);
    } finally {
      setLoading(false);
    }
  };

  const loadAllData = async () => {
    if (!customer) return;

    try {
      console.log('🔄 Carregando dados do cliente:', customer.id);

      // Carregar propriedades
      const { data: propsData, error: propsError } = await supabase
        .from('properties')
        .select('*')
        .eq('customer_id', customer.id)
        .eq('client_access_enabled', true);

      console.log('📦 Propriedades carregadas:', propsData, 'Erro:', propsError);

      if (propsError) {
        console.error('❌ Erro ao carregar propriedades:', propsError);
      }

      if (propsData) {
        // Carregar contagem de documentos para cada propriedade
        const propertiesWithCounts = await Promise.all(
          propsData.map(async (p) => {
            const { count } = await supabase
              .from('property_documents')
              .select('*', { count: 'exact', head: true })
              .eq('property_id', p.id);

            return {
              id: p.id,
              name: p.name,
              registration_number: p.registration_number,
              area: p.area,
              municipality: p.municipality,
              state: p.state,
              document_count: count || 0
            };
          })
        );

        console.log('✅ Propriedades processadas:', propertiesWithCounts);
        setProperties(propertiesWithCounts);
      }

      // Carregar projetos
      const { data: projectsData } = await supabase
        .from('engineering_projects')
        .select(`
          *,
          properties(name)
        `)
        .eq('customer_id', customer.id)
        .eq('client_visible', true);

      if (projectsData) {
        setProjects(projectsData.map(p => ({
          id: p.id,
          title: p.title,
          service_type: p.service_type,
          status: p.status,
          progress_percentage: p.progress_percentage || 0,
          current_phase: p.current_phase || 'Iniciando',
          estimated_completion_date: p.estimated_completion_date,
          property_name: p.properties?.name || 'N/A'
        })));
      }

      // Carregar notificações
      const { data: notifsData } = await supabase
        .from('client_notifications')
        .select('*')
        .eq('customer_id', customer.id)
        .order('created_at', { ascending: false })
        .limit(50);

      if (notifsData) {
        setNotifications(notifsData);
      }

      // Carregar solicitações de serviço
      const { data: requestsData } = await supabase
        .from('service_requests')
        .select('*')
        .eq('customer_id', customer.id)
        .order('created_at', { ascending: false });

      if (requestsData) {
        setServiceRequests(requestsData);
      }

      // Carregar aprovações pendentes
      const { data: approvalsData } = await supabase
        .from('service_approvals')
        .select('*')
        .eq('customer_id', customer.id)
        .order('created_at', { ascending: false });

      if (approvalsData) {
        setServiceApprovals(approvalsData);
      }
    } catch (error) {
      console.error('Erro ao carregar dados:', error);
    }
  };

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (token.trim()) {
      validateToken(token.trim());
    }
  };

  const handleLogout = () => {
    localStorage.removeItem('client_portal_token');
    setIsAuthenticated(false);
    setCustomer(null);
    setToken('');
    setProperties([]);
    setProjects([]);
    setNotifications([]);
  };

  const markNotificationAsRead = async (notificationId: string) => {
    try {
      await supabase
        .from('client_notifications')
        .update({ is_read: true, read_at: new Date().toISOString() })
        .eq('id', notificationId);

      setNotifications(prev =>
        prev.map(n => n.id === notificationId ? { ...n, is_read: true } : n)
      );
    } catch (error) {
      console.error('Erro ao marcar notificação:', error);
    }
  };

  const loadPropertyDocuments = async (propertyId: string) => {
    try {
      console.log('📄 Carregando documentos para propriedade:', propertyId);
      setLoading(true);

      // Carregar documentos
      const { data: docsData, error: docsError } = await supabase
        .from('property_documents')
        .select('*')
        .eq('property_id', propertyId)
        .order('document_type');

      console.log('📦 Documentos carregados:', docsData, 'Erro:', docsError);

      if (docsError) {
        console.error('❌ Erro ao carregar documentos:', docsError);
      }

      // Carregar anexos
      const { data: attachmentsData, error: attachmentsError } = await supabase
        .from('attachments')
        .select('*')
        .eq('entity_type', 'property')
        .eq('entity_id', propertyId)
        .order('created_at', { ascending: false });

      console.log('📎 Anexos carregados:', attachmentsData, 'Erro:', attachmentsError);

      if (attachmentsError) {
        console.error('❌ Erro ao carregar anexos:', attachmentsError);
      }

      setPropertyDocuments(docsData || []);
      setPropertyAttachments(attachmentsData || []);
      setSelectedProperty(propertyId);

      if ((!docsData || docsData.length === 0) && (!attachmentsData || attachmentsData.length === 0)) {
        console.log('⚠️ Nenhum documento ou anexo encontrado para esta propriedade');
      }
    } catch (error: any) {
      console.error('❌ Erro crítico ao carregar documentos:', error);
    } finally {
      setLoading(false);
    }
  };

  const getFileIcon = (fileType: string) => {
    if (fileType.startsWith('image/')) {
      return <ImageIcon className="w-5 h-5 text-blue-600" />;
    }
    if (fileType === 'application/pdf') {
      return <FileText className="w-5 h-5 text-red-600" />;
    }
    return <File className="w-5 h-5 text-gray-600" />;
  };

  const formatFileSize = (bytes: number) => {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  };

  const downloadAttachment = async (attachment: any) => {
    try {
      const { data, error } = await supabase.storage
        .from('attachments')
        .download(attachment.file_path);

      if (error) throw error;

      const url = window.URL.createObjectURL(data);
      const a = document.createElement('a');
      a.href = url;
      a.download = attachment.file_name;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);
    } catch (error) {
      console.error('Erro ao baixar arquivo:', error);
      alert('Erro ao baixar arquivo');
    }
  };

  const submitServiceRequest = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!customer) return;

    try {
      setLoading(true);
      const { error } = await supabase
        .from('service_requests')
        .insert([{
          customer_id: customer.id,
          ...newRequest,
          property_id: newRequest.property_id || null
        }]);

      if (error) throw error;

      alert('Solicitação enviada com sucesso!');
      setShowNewRequest(false);
      setNewRequest({
        service_type: 'topografia',
        title: '',
        description: '',
        urgency: 'normal',
        property_id: ''
      });
      loadAllData();
    } catch (error) {
      console.error('Erro ao enviar solicitação:', error);
      alert('Erro ao enviar solicitação');
    } finally {
      setLoading(false);
    }
  };

  const handleApproval = async (approvalId: string, approved: boolean, reason?: string) => {
    try {
      const { error } = await supabase
        .from('service_approvals')
        .update({
          status: approved ? 'aprovado' : 'rejeitado',
          approved_at: approved ? new Date().toISOString() : null,
          rejected_at: !approved ? new Date().toISOString() : null,
          rejection_reason: reason || null
        })
        .eq('id', approvalId);

      if (error) throw error;

      alert(approved ? 'Serviço aprovado com sucesso!' : 'Serviço rejeitado');
      loadAllData();
    } catch (error) {
      console.error('Erro ao processar aprovação:', error);
      alert('Erro ao processar aprovação');
    }
  };

  const getStatusColor = (status: string) => {
    const colors: Record<string, string> = {
      'pendente': 'bg-yellow-100 text-yellow-800',
      'em_analise': 'bg-blue-100 text-blue-800',
      'em_andamento': 'bg-purple-100 text-purple-800',
      'aprovado': 'bg-green-100 text-green-800',
      'concluido': 'bg-gray-100 text-gray-800',
      'cancelado': 'bg-red-100 text-red-800',
      'rejeitado': 'bg-red-100 text-red-800'
    };
    return colors[status] || 'bg-gray-100 text-gray-800';
  };

  const getPriorityColor = (priority: string) => {
    const colors: Record<string, string> = {
      'baixa': 'text-gray-600',
      'normal': 'text-blue-600',
      'alta': 'text-orange-600',
      'urgente': 'text-red-600'
    };
    return colors[priority] || 'text-gray-600';
  };

  // Login Screen
  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-blue-50 to-blue-100 flex items-center justify-center p-4">
        <div className="bg-white rounded-2xl shadow-xl p-8 w-full max-w-md">
          <div className="text-center mb-8">
            <div className="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <Building className="w-10 h-10 text-white" />
            </div>
            <h1 className="text-3xl font-bold text-gray-900 mb-2">Portal do Cliente</h1>
            <p className="text-gray-600">Acesse suas informações e projetos</p>
          </div>

          {loading ? (
            <div className="text-center py-8">
              <div className="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
              <p className="mt-4 text-gray-600">Validando acesso...</p>
            </div>
          ) : (
            <form onSubmit={handleLogin} className="space-y-6">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  Token de Acesso
                </label>
                <input
                  type="text"
                  value={token}
                  onChange={(e) => setToken(e.target.value)}
                  placeholder="Cole seu token de acesso aqui"
                  className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  required
                />
                <p className="mt-2 text-sm text-gray-500">
                  O token foi enviado para você por WhatsApp ou e-mail
                </p>
              </div>

              <div className="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <h3 className="font-semibold text-blue-900 mb-2 text-sm">Como acessar:</h3>
                <ol className="text-sm text-blue-800 space-y-1 list-decimal list-inside">
                  <li>Clique no link recebido por WhatsApp</li>
                  <li>Se não funcionar, copie o token da mensagem</li>
                  <li>Cole o token no campo acima e clique em Entrar</li>
                </ol>
              </div>

              <button
                type="submit"
                disabled={loading}
                className="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors disabled:bg-gray-400"
              >
                {loading ? 'Validando...' : 'Acessar Portal'}
              </button>
            </form>
          )}

          <div className="mt-6 text-center text-sm text-gray-600">
            Não recebeu seu token? Entre em contato com o escritório.
          </div>
        </div>
      </div>
    );
  }

  const unreadCount = notifications.filter(n => !n.is_read).length;
  const pendingApprovalsCount = serviceApprovals.filter(a => a.status === 'pendente').length;

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Header */}
      <header className="bg-white border-b border-gray-200 sticky top-0 z-10">
        <div className="max-w-7xl mx-auto px-4 py-4">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center">
                <Building className="w-6 h-6 text-white" />
              </div>
              <div>
                <h1 className="text-xl font-bold text-gray-900">Portal do Cliente</h1>
                <p className="text-sm text-gray-600">Olá, {customer?.name}</p>
              </div>
            </div>
            <button
              onClick={handleLogout}
              className="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
            >
              <LogOut className="w-5 h-5" />
              <span className="hidden sm:inline">Sair</span>
            </button>
          </div>
        </div>
      </header>

      {/* Navigation Tabs */}
      <nav className="bg-white border-b border-gray-200">
        <div className="max-w-7xl mx-auto px-4">
          <div className="flex gap-1 overflow-x-auto">
            <button
              onClick={() => setActiveTab('home')}
              className={`flex items-center gap-2 px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === 'home'
                  ? 'border-blue-600 text-blue-600'
                  : 'border-transparent text-gray-600 hover:text-gray-900'
              }`}
            >
              <Home className="w-5 h-5" />
              Início
            </button>
            <button
              onClick={() => setActiveTab('properties')}
              className={`flex items-center gap-2 px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === 'properties'
                  ? 'border-blue-600 text-blue-600'
                  : 'border-transparent text-gray-600 hover:text-gray-900'
              }`}
            >
              <Building className="w-5 h-5" />
              Imóveis ({properties.length})
            </button>
            <button
              onClick={() => setActiveTab('projects')}
              className={`flex items-center gap-2 px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === 'projects'
                  ? 'border-blue-600 text-blue-600'
                  : 'border-transparent text-gray-600 hover:text-gray-900'
              }`}
            >
              <FileText className="w-5 h-5" />
              Projetos ({projects.length})
            </button>
            <button
              onClick={() => setActiveTab('services')}
              className={`relative flex items-center gap-2 px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === 'services'
                  ? 'border-blue-600 text-blue-600'
                  : 'border-transparent text-gray-600 hover:text-gray-900'
              }`}
            >
              <MessageSquare className="w-5 h-5" />
              Serviços
              {pendingApprovalsCount > 0 && (
                <span className="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">
                  {pendingApprovalsCount}
                </span>
              )}
            </button>
            <button
              onClick={() => setActiveTab('notifications')}
              className={`relative flex items-center gap-2 px-4 py-3 font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === 'notifications'
                  ? 'border-blue-600 text-blue-600'
                  : 'border-transparent text-gray-600 hover:text-gray-900'
              }`}
            >
              <Bell className="w-5 h-5" />
              Notificações
              {unreadCount > 0 && (
                <span className="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">
                  {unreadCount}
                </span>
              )}
            </button>
          </div>
        </div>
      </nav>

      {/* Main Content */}
      <main className="max-w-7xl mx-auto px-4 py-6">
        {/* Home Tab */}
        {activeTab === 'home' && (
          <div className="space-y-6">
            <div className="bg-gradient-to-r from-blue-600 to-blue-700 rounded-lg p-6 text-white">
              <h2 className="text-2xl font-bold mb-2">Bem-vindo ao seu portal!</h2>
              <p className="text-blue-100">
                Aqui você pode acompanhar seus imóveis, projetos em andamento, aprovar serviços e muito mais.
              </p>
            </div>

            {/* Stats Cards */}
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <div className="bg-white rounded-lg p-6 shadow-sm">
                <div className="flex items-center justify-between mb-2">
                  <Building className="w-8 h-8 text-blue-600" />
                  <span className="text-3xl font-bold text-gray-900">{properties.length}</span>
                </div>
                <p className="text-gray-600 font-medium">Imóveis</p>
              </div>

              <div className="bg-white rounded-lg p-6 shadow-sm">
                <div className="flex items-center justify-between mb-2">
                  <FileText className="w-8 h-8 text-green-600" />
                  <span className="text-3xl font-bold text-gray-900">{projects.length}</span>
                </div>
                <p className="text-gray-600 font-medium">Projetos Ativos</p>
              </div>

              <div className="bg-white rounded-lg p-6 shadow-sm">
                <div className="flex items-center justify-between mb-2">
                  <CheckSquare className="w-8 h-8 text-orange-600" />
                  <span className="text-3xl font-bold text-gray-900">{pendingApprovalsCount}</span>
                </div>
                <p className="text-gray-600 font-medium">Pendente Aprovação</p>
              </div>

              <div className="bg-white rounded-lg p-6 shadow-sm">
                <div className="flex items-center justify-between mb-2">
                  <Bell className="w-8 h-8 text-red-600" />
                  <span className="text-3xl font-bold text-gray-900">{unreadCount}</span>
                </div>
                <p className="text-gray-600 font-medium">Notificações</p>
              </div>
            </div>

            {/* Pending Approvals */}
            {pendingApprovalsCount > 0 && (
              <div className="bg-white rounded-lg shadow-sm p-6">
                <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <AlertCircle className="w-5 h-5 text-orange-600" />
                  Aprovações Pendentes
                </h3>
                <div className="space-y-3">
                  {serviceApprovals.filter(a => a.status === 'pendente').slice(0, 3).map(approval => (
                    <div key={approval.id} className="border border-orange-200 rounded-lg p-4 bg-orange-50">
                      <div className="flex items-start justify-between mb-2">
                        <div className="flex-1">
                          <h4 className="font-semibold text-gray-900">{approval.title}</h4>
                          <p className="text-sm text-gray-600 mt-1">{approval.description}</p>
                        </div>
                      </div>
                      <div className="flex items-center justify-between mt-3">
                        <div className="text-sm text-gray-600">
                          <span className="font-semibold">Valor:</span> R$ {approval.estimated_value.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                          {approval.estimated_days && (
                            <span className="ml-4"><span className="font-semibold">Prazo:</span> {approval.estimated_days} dias</span>
                          )}
                        </div>
                        <button
                          onClick={() => setActiveTab('services')}
                          className="text-blue-600 hover:text-blue-700 font-medium text-sm flex items-center gap-1"
                        >
                          Ver detalhes
                          <ArrowRight className="w-4 h-4" />
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Recent Projects */}
            {projects.length > 0 && (
              <div className="bg-white rounded-lg shadow-sm p-6">
                <h3 className="text-lg font-bold text-gray-900 mb-4">Projetos em Andamento</h3>
                <div className="space-y-4">
                  {projects.filter(p => p.status !== 'concluido').slice(0, 3).map(project => (
                    <div key={project.id} className="border border-gray-200 rounded-lg p-4">
                      <div className="flex items-start justify-between mb-2">
                        <div>
                          <h4 className="font-semibold text-gray-900">{project.title}</h4>
                          <p className="text-sm text-gray-600">{project.property_name}</p>
                        </div>
                        <span className={`px-2 py-1 rounded text-xs font-medium ${getStatusColor(project.status)}`}>
                          {project.status}
                        </span>
                      </div>
                      <div className="mt-3">
                        <div className="flex items-center justify-between text-sm text-gray-600 mb-1">
                          <span>{project.current_phase}</span>
                          <span className="font-semibold">{project.progress_percentage}%</span>
                        </div>
                        <div className="w-full bg-gray-200 rounded-full h-2">
                          <div
                            className="bg-blue-600 h-2 rounded-full transition-all"
                            style={{ width: `${project.progress_percentage}%` }}
                          />
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* Properties Tab */}
        {activeTab === 'properties' && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <h2 className="text-2xl font-bold text-gray-900">Meus Imóveis</h2>
            </div>

            {loading ? (
              <div className="bg-white rounded-lg p-8 text-center">
                <div className="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
                <p className="text-gray-600">Carregando imóveis...</p>
              </div>
            ) : properties.length === 0 ? (
              <div className="bg-white rounded-lg p-8 text-center">
                <Building className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                <p className="text-gray-600 font-medium mb-2">Nenhum imóvel disponível</p>
                <p className="text-sm text-gray-500">
                  Entre em contato com o escritório se você possui imóveis cadastrados.
                </p>
              </div>
            ) : (
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {properties.map(property => (
                  <div key={property.id} className="bg-white rounded-lg shadow-sm p-6">
                    <div className="flex items-start justify-between mb-4">
                      <div>
                        <h3 className="text-lg font-bold text-gray-900">{property.name}</h3>
                        <p className="text-sm text-gray-600">Matrícula: {property.registration_number}</p>
                      </div>
                      <div className="flex gap-2">
                        {selectedProperty === property.id ? (
                          <button
                            onClick={() => {
                              setSelectedProperty(null);
                              setPropertyDocuments([]);
                            }}
                            className="px-3 py-1 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium"
                          >
                            Fechar
                          </button>
                        ) : (
                          <button
                            onClick={() => loadPropertyDocuments(property.id)}
                            disabled={loading}
                            className="px-3 py-1 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-100 transition-colors text-sm font-medium disabled:opacity-50"
                          >
                            {loading ? 'Carregando...' : 'Ver Documentos'}
                          </button>
                        )}
                      </div>
                    </div>

                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between">
                        <span className="text-gray-600">Área:</span>
                        <span className="font-semibold text-gray-900">{property.area.toLocaleString('pt-BR')} ha</span>
                      </div>
                      <div className="flex justify-between">
                        <span className="text-gray-600">Localização:</span>
                        <span className="font-semibold text-gray-900">{property.municipality}/{property.state}</span>
                      </div>
                      <div className="flex justify-between">
                        <span className="text-gray-600">Documentos:</span>
                        <span className="font-semibold text-gray-900">{property.document_count}</span>
                      </div>
                    </div>

                    {selectedProperty === property.id && (
                      <div className="mt-4 pt-4 border-t border-gray-200 space-y-4">
                        {/* Documentos Cadastrais */}
                        <div>
                          <h4 className="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                            <FileText className="w-5 h-5" />
                            Documentos Cadastrais
                          </h4>
                          {propertyDocuments.length === 0 ? (
                            <div className="text-center py-4 bg-gray-50 rounded">
                              <p className="text-sm text-gray-600">Nenhum documento cadastrado.</p>
                            </div>
                          ) : (
                            <div className="space-y-2">
                              {propertyDocuments.map(doc => (
                                <div key={doc.id} className="flex items-center justify-between p-3 bg-gray-50 rounded hover:bg-gray-100 transition-colors">
                                  <div className="flex items-center gap-3">
                                    <FileText className="w-5 h-5 text-blue-600" />
                                    <div>
                                      <span className="text-sm font-medium text-gray-900">{doc.document_type}</span>
                                      {doc.expiration_date && (
                                        <p className="text-xs text-gray-500">
                                          Validade: {new Date(doc.expiration_date).toLocaleDateString('pt-BR')}
                                        </p>
                                      )}
                                    </div>
                                  </div>
                                  {doc.expiration_date && new Date(doc.expiration_date) < new Date() && (
                                    <span className="px-2 py-1 bg-red-100 text-red-800 text-xs rounded font-medium">
                                      Vencido
                                    </span>
                                  )}
                                  {doc.expiration_date &&
                                    new Date(doc.expiration_date) > new Date() &&
                                    new Date(doc.expiration_date) < new Date(Date.now() + 30 * 24 * 60 * 60 * 1000) && (
                                    <span className="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs rounded font-medium">
                                      Vence em breve
                                    </span>
                                  )}
                                </div>
                              ))}
                            </div>
                          )}
                        </div>

                        {/* Anexos */}
                        <div>
                          <h4 className="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                            <Paperclip className="w-5 h-5" />
                            Arquivos e Anexos
                          </h4>
                          {propertyAttachments.length === 0 ? (
                            <div className="text-center py-4 bg-gray-50 rounded">
                              <Paperclip className="w-12 h-12 text-gray-400 mx-auto mb-2" />
                              <p className="text-sm text-gray-600">Nenhum arquivo anexado.</p>
                            </div>
                          ) : (
                            <div className="grid grid-cols-1 gap-2">
                              {propertyAttachments.map(attachment => (
                                <div key={attachment.id} className="flex items-center justify-between p-3 bg-white border border-gray-200 rounded-lg hover:border-blue-300 hover:bg-blue-50 transition-all">
                                  <div className="flex items-center gap-3 flex-1 min-w-0">
                                    {getFileIcon(attachment.file_type)}
                                    <div className="flex-1 min-w-0">
                                      <p className="text-sm font-medium text-gray-900 truncate">
                                        {attachment.file_name}
                                      </p>
                                      <div className="flex items-center gap-2 text-xs text-gray-500">
                                        <span>{formatFileSize(attachment.file_size)}</span>
                                        <span>•</span>
                                        <span>{new Date(attachment.created_at).toLocaleDateString('pt-BR')}</span>
                                      </div>
                                      {attachment.description && (
                                        <p className="text-xs text-gray-600 mt-1 truncate">
                                          {attachment.description}
                                        </p>
                                      )}
                                    </div>
                                  </div>
                                  <button
                                    onClick={() => downloadAttachment(attachment)}
                                    className="ml-2 p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition-colors flex-shrink-0"
                                    title="Baixar arquivo"
                                  >
                                    <Download className="w-5 h-5" />
                                  </button>
                                </div>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* Projects Tab */}
        {activeTab === 'projects' && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <h2 className="text-2xl font-bold text-gray-900">Meus Projetos</h2>
            </div>

            {projects.length === 0 ? (
              <div className="bg-white rounded-lg p-8 text-center">
                <FileText className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                <p className="text-gray-600">Nenhum projeto em andamento.</p>
              </div>
            ) : (
              <div className="space-y-4">
                {projects.map(project => (
                  <div key={project.id} className="bg-white rounded-lg shadow-sm p-6">
                    <div className="flex items-start justify-between mb-4">
                      <div className="flex-1">
                        <div className="flex items-start gap-3">
                          <div className="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                            <FileText className="w-6 h-6 text-blue-600" />
                          </div>
                          <div className="flex-1">
                            <h3 className="text-lg font-bold text-gray-900">{project.title}</h3>
                            <p className="text-sm text-gray-600">
                              {project.service_type} • {project.property_name}
                            </p>
                            {project.estimated_completion_date && (
                              <p className="text-sm text-gray-500 mt-1">
                                Previsão de conclusão: {new Date(project.estimated_completion_date).toLocaleDateString('pt-BR')}
                              </p>
                            )}
                          </div>
                        </div>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-xs font-medium ${getStatusColor(project.status)}`}>
                        {project.status}
                      </span>
                    </div>

                    <div className="space-y-3">
                      <div>
                        <div className="flex items-center justify-between text-sm mb-2">
                          <span className="text-gray-700 font-medium">{project.current_phase}</span>
                          <span className="text-gray-900 font-bold">{project.progress_percentage}%</span>
                        </div>
                        <div className="w-full bg-gray-200 rounded-full h-3">
                          <div
                            className="bg-gradient-to-r from-blue-500 to-blue-600 h-3 rounded-full transition-all"
                            style={{ width: `${project.progress_percentage}%` }}
                          />
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* Services Tab */}
        {activeTab === 'services' && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <h2 className="text-2xl font-bold text-gray-900">Serviços</h2>
              <button
                onClick={() => setShowNewRequest(true)}
                className="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
              >
                <Plus className="w-5 h-5" />
                Nova Solicitação
              </button>
            </div>

            {/* Pending Approvals Section */}
            {serviceApprovals.filter(a => a.status === 'pendente').length > 0 && (
              <div className="bg-white rounded-lg shadow-sm p-6">
                <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <CheckSquare className="w-5 h-5 text-orange-600" />
                  Aguardando sua Aprovação
                </h3>
                <div className="space-y-4">
                  {serviceApprovals.filter(a => a.status === 'pendente').map(approval => (
                    <div key={approval.id} className="border-2 border-orange-200 rounded-lg p-4 bg-orange-50">
                      <div className="flex items-start justify-between mb-3">
                        <div className="flex-1">
                          <h4 className="font-bold text-gray-900 text-lg">{approval.title}</h4>
                          <p className="text-gray-700 mt-1">{approval.description}</p>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4 mb-4 p-3 bg-white rounded">
                        <div>
                          <span className="text-sm text-gray-600">Valor Estimado</span>
                          <p className="text-xl font-bold text-gray-900">
                            R$ {approval.estimated_value.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                          </p>
                        </div>
                        {approval.estimated_days && (
                          <div>
                            <span className="text-sm text-gray-600">Prazo Estimado</span>
                            <p className="text-xl font-bold text-gray-900">{approval.estimated_days} dias</p>
                          </div>
                        )}
                      </div>

                      {approval.expires_at && (
                        <p className="text-sm text-orange-700 mb-3">
                          Válido até: {new Date(approval.expires_at).toLocaleDateString('pt-BR')}
                        </p>
                      )}

                      <div className="flex gap-3">
                        <button
                          onClick={() => {
                            if (confirm('Confirma a aprovação deste serviço?')) {
                              handleApproval(approval.id, true);
                            }
                          }}
                          className="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
                        >
                          <CheckCircle className="w-5 h-5" />
                          Aprovar
                        </button>
                        <button
                          onClick={() => {
                            const reason = prompt('Motivo da rejeição (opcional):');
                            if (reason !== null) {
                              handleApproval(approval.id, false, reason);
                            }
                          }}
                          className="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
                        >
                          <XCircle className="w-5 h-5" />
                          Rejeitar
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Service Requests */}
            <div className="bg-white rounded-lg shadow-sm p-6">
              <h3 className="text-lg font-bold text-gray-900 mb-4">Minhas Solicitações</h3>

              {serviceRequests.length === 0 ? (
                <p className="text-gray-600 text-center py-8">Nenhuma solicitação ainda.</p>
              ) : (
                <div className="space-y-3">
                  {serviceRequests.map(request => (
                    <div key={request.id} className="border border-gray-200 rounded-lg p-4">
                      <div className="flex items-start justify-between mb-2">
                        <div className="flex-1">
                          <h4 className="font-semibold text-gray-900">{request.title}</h4>
                          <p className="text-sm text-gray-600 mt-1">{request.description}</p>
                          <div className="flex items-center gap-4 mt-2 text-sm">
                            <span className="text-gray-500">
                              {new Date(request.created_at).toLocaleDateString('pt-BR')}
                            </span>
                            <span className={getPriorityColor(request.urgency)}>
                              Urgência: {request.urgency}
                            </span>
                          </div>
                        </div>
                        <span className={`px-2 py-1 rounded text-xs font-medium ${getStatusColor(request.status)}`}>
                          {request.status}
                        </span>
                      </div>
                      {request.response_notes && (
                        <div className="mt-3 pt-3 border-t border-gray-200">
                          <p className="text-sm text-gray-700">
                            <span className="font-semibold">Resposta:</span> {request.response_notes}
                          </p>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </div>

            {/* New Request Modal */}
            {showNewRequest && (
              <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
                <div className="bg-white rounded-lg max-w-2xl w-full p-6">
                  <h3 className="text-xl font-bold text-gray-900 mb-4">Nova Solicitação de Serviço</h3>

                  <form onSubmit={submitServiceRequest} className="space-y-4">
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">
                        Tipo de Serviço
                      </label>
                      <select
                        value={newRequest.service_type}
                        onChange={(e) => setNewRequest({ ...newRequest, service_type: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                        required
                      >
                        <option value="topografia">Topografia</option>
                        <option value="engenharia">Engenharia</option>
                        <option value="projeto">Projeto</option>
                        <option value="consultoria">Consultoria</option>
                        <option value="outro">Outro</option>
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">
                        Imóvel (opcional)
                      </label>
                      <select
                        value={newRequest.property_id}
                        onChange={(e) => setNewRequest({ ...newRequest, property_id: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                      >
                        <option value="">Selecione um imóvel (opcional)</option>
                        {properties.map(prop => (
                          <option key={prop.id} value={prop.id}>{prop.name}</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">
                        Título
                      </label>
                      <input
                        type="text"
                        value={newRequest.title}
                        onChange={(e) => setNewRequest({ ...newRequest, title: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                        required
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">
                        Descrição
                      </label>
                      <textarea
                        value={newRequest.description}
                        onChange={(e) => setNewRequest({ ...newRequest, description: e.target.value })}
                        rows={4}
                        className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                        required
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">
                        Urgência
                      </label>
                      <select
                        value={newRequest.urgency}
                        onChange={(e) => setNewRequest({ ...newRequest, urgency: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                      >
                        <option value="baixa">Baixa</option>
                        <option value="normal">Normal</option>
                        <option value="alta">Alta</option>
                        <option value="urgente">Urgente</option>
                      </select>
                    </div>

                    <div className="flex gap-3 pt-4">
                      <button
                        type="button"
                        onClick={() => setShowNewRequest(false)}
                        className="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
                      >
                        Cancelar
                      </button>
                      <button
                        type="submit"
                        disabled={loading}
                        className="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:bg-gray-400"
                      >
                        {loading ? 'Enviando...' : 'Enviar Solicitação'}
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            )}
          </div>
        )}

        {/* Notifications Tab */}
        {activeTab === 'notifications' && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <h2 className="text-2xl font-bold text-gray-900">Notificações</h2>
              {unreadCount > 0 && (
                <button
                  onClick={() => {
                    notifications.filter(n => !n.is_read).forEach(n => markNotificationAsRead(n.id));
                  }}
                  className="text-sm text-blue-600 hover:text-blue-700 font-medium"
                >
                  Marcar todas como lidas
                </button>
              )}
            </div>

            {notifications.length === 0 ? (
              <div className="bg-white rounded-lg p-8 text-center">
                <Bell className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                <p className="text-gray-600">Nenhuma notificação ainda.</p>
              </div>
            ) : (
              <div className="space-y-2">
                {notifications.map(notification => (
                  <div
                    key={notification.id}
                    className={`bg-white rounded-lg p-4 border-l-4 ${
                      notification.is_read
                        ? 'border-gray-300 opacity-60'
                        : 'border-blue-600 shadow-sm'
                    }`}
                  >
                    <div className="flex items-start gap-3">
                      <div className={`w-2 h-2 rounded-full mt-2 ${notification.is_read ? 'bg-gray-400' : 'bg-blue-600'}`} />
                      <div className="flex-1">
                        <div className="flex items-start justify-between mb-1">
                          <h4 className={`font-semibold ${notification.is_read ? 'text-gray-700' : 'text-gray-900'}`}>
                            {notification.title}
                          </h4>
                          <span className="text-xs text-gray-500 whitespace-nowrap ml-2">
                            {new Date(notification.created_at).toLocaleDateString('pt-BR')}
                          </span>
                        </div>
                        <p className="text-sm text-gray-600 mb-2">{notification.message}</p>
                        <div className="flex items-center gap-3">
                          {!notification.is_read && (
                            <button
                              onClick={() => markNotificationAsRead(notification.id)}
                              className="text-xs text-blue-600 hover:text-blue-700 font-medium"
                            >
                              Marcar como lida
                            </button>
                          )}
                          {notification.action_url && (
                            <a
                              href={notification.action_url}
                              className="text-xs text-blue-600 hover:text-blue-700 font-medium"
                            >
                              {notification.action_label || 'Ver mais'}
                            </a>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}
      </main>
    </div>
  );
}
