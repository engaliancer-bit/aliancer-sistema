# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stability Mode — set to "true" to disable all realtime subscriptions.
# Useful for low-bandwidth connections, debugging, or when realtime causes issues.
# Can also be toggled at runtime without redeploy:
#   Enable:  localStorage.setItem('stability_mode', 'true')  then reload
#   Disable: localStorage.setItem('stability_mode', 'false') then reload
#   Reset:   localStorage.removeItem('stability_mode')       then reload
VITE_STABILITY_MODE=false
